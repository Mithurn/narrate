# Narrate Environment Variables
#
# These are read server-side only (by server/app.ts, and by vite.config.ts's
# dev middleware) — never exposed to the browser bundle.

# RapidAPI key for the "Real-Time News Data" API (used for news aggregation)
# Subscribe at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-news-data
RAPIDAPI_KEY=

# Groq API key for AI summarization
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=
